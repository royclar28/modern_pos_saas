// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  STORE_ADMIN
  CASHIER
}

model Store {
  id           String   @id @default(cuid()) // Or UUID depending on preference, but usually UUID or CUID for stores
  name         String
  primaryColor String?  @default("#3B82F6")
  logoUrl      String?
  createdAt    DateTime @default(now())

  // SaaS Fields
  isActive     Boolean  @default(true)
  plan         String   @default("FREE")
  rif          String?
  ownerEmail   String?

  // Relations
  users        User[]
  customers    Customer[]
  items        Item[]
  sales        Sale[]
  configs      StoreConfig[]
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  storeId  String
  store    Store  @relation(fields: [storeId], references: [id])

  // People data from legacy `ospos_people`
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?

  // Relations
  sales Sale[]

  // Sync fields
  telegramChatId String?
  role      Role      @default(CASHIER)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Customer {
  id            Int     @id @default(autoincrement())
  companyName   String?
  accountNumber String? @unique
  taxable       Boolean @default(true)

  storeId       String
  store         Store   @relation(fields: [storeId], references: [id])

  // People data from legacy `ospos_people`
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?

  // Relations
  sales Sale[]

  // Sync fields
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Item {
  id                  Int     @id @default(autoincrement())
  name                String
  category            String
  itemNumber          String? @unique
  description         String?

  storeId             String
  store               Store   @relation(fields: [storeId], references: [id])
  costPrice           Decimal @db.Decimal(15, 2)
  unitPrice           Decimal @db.Decimal(15, 2)
  reorderLevel        Decimal @default(0) @db.Decimal(15, 2)
  receivingQuantity   Int     @default(1)
  allowAltDescription Boolean @default(false)
  isSerialized        Boolean @default(false)

  // Relations
  saleItems SaleItem[]

  // Sync fields
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Sale {
  id            Int      @id @default(autoincrement())
  invoiceNumber String?  @unique
  comment       String?
  saleTime      DateTime @default(now())
  terminalId    String   @default("CAJA_01") // Multi-terminal support

  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])

  // Relations
  customerId Int?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  employeeId Int
  employee   User       @relation(fields: [employeeId], references: [id])
  items      SaleItem[]

  // Sync fields
  paymentMethod String    @default("DIVISA") // 'DIVISA', 'EFECTIVO_BS', 'PAGO_MOVIL', 'PUNTO', 'FIADO'
  status        String    @default("PAGADO") // 'PENDIENTE', 'PAGADO' (Fiados)
  total         Decimal   @default(0) @db.Decimal(15, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(15, 2)
  dueDate       DateTime?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model SaleItem {
  id                Int     @id @default(autoincrement())
  line              Int     @default(0)
  description       String?
  serialNumber      String?
  quantityPurchased Decimal @default(0) @db.Decimal(15, 2)
  itemCostPrice     Decimal @db.Decimal(15, 2)
  itemUnitPrice     Decimal @db.Decimal(15, 2)
  discountPercent   Decimal @default(0) @db.Decimal(15, 2)

  // Relations
  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  itemId Int
  item   Item @relation(fields: [itemId], references: [id])

  // Sync fields
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([saleId, itemId, line])
}

model StoreConfig {
  id      String @id @default(cuid())
  key     String
  value   String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  // Sync fields
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([storeId, key])
}
