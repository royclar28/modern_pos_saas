# .env.example - Configuración del Entorno de Desarrollo

# ==========================
# DATABASE (PostgreSQL)
# ==========================
DB_USER=postgres
DB_PASSWORD=r00t_password_segura
DB_NAME=modern_pos

# ==========================
# BACKEND (NestJS)
# ==========================
# IMPORTANTE: En Docker, el host de la BD es el nombre del contenedor ("postgres"), no localhost.
DATABASE_URL="postgresql://postgres:r00t_password_segura@postgres:5432/modern_pos?schema=public"
JWT_SECRET="mi_secreto_super_seguro_para_jwt_dev_123"

# ==========================
# FRONTEND (React/Vite)
# ==========================
# El frontend se ejecuta en el navegador del usuario final, 
# por lo que debe hacer la petición a localhost (la máquina host), no al contenedor interno.
VITE_API_URL="http://localhost:3333/api"

# ==========================
# AI INTEGRATION (Groq/OpenAI)
# ==========================
# Llave secreta para OCR de facturas. No omitir la variable aunque esté vacía.
OPENAI_API_KEY=""
